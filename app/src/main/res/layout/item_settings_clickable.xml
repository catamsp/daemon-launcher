<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_item_clickable_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="32dp"
    android:paddingVertical="14dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/settings_item_clickable_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="@dimen/font_size_medium"
            tools:text="Clickable Setting" />

        <TextView
            android:id="@+id/settings_item_clickable_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/font_size_small"
            android:visibility="gone"
            tools:text="Action description"
            tools:visibility="visible" />
    </LinearLayout>

    <ImageView
        android:id="@+id/settings_item_clickable_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        tools:visibility="visible"
        tools:src="@drawable/baseline_settings_24"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/settings_item_clickable_remove"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="6dp"
        android:src="@drawable/baseline_close_24"
        android:visibility="gone"
        tools:visibility="visible"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/content_description_settings_actions_row_button_remove" />

    <ImageView
        android:id="@+id/settings_item_clickable_arrow"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/baseline_navigate_next_24"
        app:tint="?android:attr/textColorSecondary"
        android:importantForAccessibility="no" />
</LinearLayout>
